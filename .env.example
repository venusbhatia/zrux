# zrux - Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local. Never share these in Traces, screenshots, or the README.

# --- LLM (OpenRouter via Vercel AI SDK) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_PRIMARY_MODEL=anthropic/claude-sonnet-4-6
OPENROUTER_FALLBACK_MODEL=anthropic/claude-haiku-4-5

# --- Supabase (Postgres + pgvector + RLS) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Supavisor transaction-mode pooler connection string
DATABASE_URL=

# --- Composio (managed OAuth for connectors) ---
COMPOSIO_API_KEY=
# Per-app auth config ids (ac_...), created once in the Composio dashboard.
COMPOSIO_GMAIL_AUTH_CONFIG_ID=
COMPOSIO_CALENDAR_AUTH_CONFIG_ID=
COMPOSIO_LINEAR_AUTH_CONFIG_ID=
COMPOSIO_SLACK_AUTH_CONFIG_ID=
COMPOSIO_NOTION_AUTH_CONFIG_ID=
COMPOSIO_GITHUB_AUTH_CONFIG_ID=

# --- Redis / Upstash (semantic cache + circuit breaker state) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Embeddings (OpenAI text-embedding-3-large @ 1536 dims) ---
OPENAI_API_KEY=

# --- Reranker (Cohere Rerank 3.5) ---
COHERE_API_KEY=

# --- Speech to text (Deepgram Nova-3 batch, diarized) ---
DEEPGRAM_API_KEY=

# --- Trigger.dev (ingestion jobs) ---
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_ID=

# --- Supermemory (Layer 3 personalization) ---
SUPERMEMORY_API_KEY=

# --- Langfuse (observability) ---
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# --- Webhook secrets (HMAC verification for Event-mode ingestion) ---
WEBHOOK_SECRET_GMAIL=
WEBHOOK_SECRET_LINEAR=
WEBHOOK_SECRET_SLACK=
WEBHOOK_SECRET_GITHUB=

# --- App / Auth (NextAuth) ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Google OAuth (NextAuth sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Ingestion config ---
INGEST_LOOKBACK_DAYS=90
# Optional LLM gloss on unstructured chunks (cost lever; off by default).
ENRICH_GLOSS=false
# Dev-only: resolve a tenant without signing in (non-production fallback).
DEV_USER_ID=

# --- Telegram (optional delivery surface, stretch) ---
TELEGRAM_BOT_TOKEN=
