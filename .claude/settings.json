{
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(cat ./.env*)",
      "Bash(echo *KEY*)",
      "Bash(echo *SECRET*)",
      "Bash(echo *TOKEN*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$FILE_PATH\" --log-level silent 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$BASH_COMMAND\" | grep -qE '(cat|print|echo|curl).*(env|secret|token|key)'; then echo 'Blocked: potential credential exposure' >&2; exit 2; fi"
          }
        ]
      }
    ]
  },
  "env": {
    "FORCE_COLOR": "1",
    "NODE_ENV": "development"
  },
  "model": "claude-sonnet-4-6",
  "cleanupPeriodDays": 30
}
